#!/bin/sh
# Gradle wrapper script - wrapper jar generated by CI if missing
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar
if [ ! -f "$CLASSPATH" ]; then
    echo "Downloading Gradle wrapper..."
    curl -sL "https://raw.githubusercontent.com/gradle/gradle/v8.7.0/gradle/wrapper/gradle-wrapper.jar" -o "$CLASSPATH" 2>/dev/null
    # Fallback: generate via gradle if available
    if [ ! -f "$CLASSPATH" ]; then
        echo "Trying gradle wrapper generation..."
        gradle wrapper --gradle-version 8.7 2>/dev/null || true
    fi
fi
exec java -cp "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
